# Google Gemini API Key (무료: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Teams Workflows Webhook URL (채널에서 Workflows → "Post to a channel when a webhook request is received" 로 생성)
TEAMS_WEBHOOK_URL=https://prod-xx.westus.logic.azure.com:443/workflows/xxxxxxx/triggers/manual/paths/invoke?...

# 서버 포트
PORT=3000
